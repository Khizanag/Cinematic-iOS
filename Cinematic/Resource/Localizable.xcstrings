{
  "sourceLanguage": "en",
  "strings": {
    "about.body": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cinematic ist eine Referenz-Implementierung von MVI + Clean Architecture in SwiftUI. Jede Schicht liegt in einem eigenen Swift-Package, jeder Screen ist eine Reducer-gesteuerte Zustandsmaschine, und das gesamte Projekt ist für Menschen dokumentiert, die durch das Lesen von echtem Code lernen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cinematic is a reference implementation of MVI + Clean Architecture in SwiftUI. Every layer lives in its own Swift package, every screen is a reducer-driven state machine, and the whole project is documented for people who learn by reading real code."
          }
        }
      }
    },
    "about.headline": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Architektur, die man lesen kann"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An architecture you can read"
          }
        }
      }
    },
